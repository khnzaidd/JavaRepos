class NewSearchingAlgos extends SearchingAlgos{
	public int search(int[] a,int data){
		if (low<=high){
			int mid=(low+high)/2;
			if(data==a[mid]){
				return mid;
                        }else if(data<a[mid]){
                                return search(a,low,mid-1,data);
                        }else if(data>a[mid]){
				return search(a,mid+1,high,data);
			}
		}
		return -1;
        }


